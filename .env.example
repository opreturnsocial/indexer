DATABASE_URL="file:./dev.db"

# Bitcoin Core RPC (Polar defaults)
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=polaruser
BITCOIN_RPC_PASS=polarpass

# Block height to start scanning from (0 = genesis, 940000 = first mainnet ORS transaction)
START_BLOCK=0

PORT=3010

# Secret token for internal endpoints (e.g. /rescan). Set a strong random value.
INTERNAL_TOKEN=
